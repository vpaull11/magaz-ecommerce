# ─── Magaz — Example Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to version control!

# ─── Database ──────────────────────────────────────────────────────────────────
# Use sslmode=require in production!
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/magaz?sslmode=require
PAYMENT_DB_URL=postgres://USER:PASSWORD@localhost:5432/magaz?sslmode=require

# ─── Server ────────────────────────────────────────────────────────────────────
SERVER_ADDR=:8080
PAYMENT_ADDR=:8081
ENV=development
# Set ENV=production for production deployments

# ─── Secrets — MUST be 32+ random characters ──────────────────────────────────
# Generate strong secrets with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_32_RANDOM_CHARS_HERE!!
CSRF_SECRET=REPLACE_WITH_ANOTHER_32_CHARS_HERE!

# ─── Payment service ───────────────────────────────────────────────────────────
PAYMENT_URL=http://localhost:8081
PAYMENT_SECRET=REPLACE_WITH_STRONG_SHARED_SECRET_HERE

# ─── File uploads ──────────────────────────────────────────────────────────────
UPLOADS_DIR=uploads
